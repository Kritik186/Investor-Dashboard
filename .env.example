# ── Backend ──────────────────────────────────────────────────────────────────

# Database connection string.
# SQLite (default for local dev, no setup needed):
#   DATABASE_URL=sqlite:///./insider.db
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@localhost:5432/InsiderDB

# SEC EDGAR User-Agent (required). Must identify your app and contact.
SEC_USER_AGENT=YourCompany/InsiderDashboard/1.0 (your-email@example.com)

# SSL verification for outbound HTTPS requests (SEC + Yahoo Finance).
# Default: 1 (enabled). Set to 0 only for local dev behind a corporate proxy
# that uses a custom CA. For production, keep enabled and install the CA cert instead.
# SEC_VERIFY_SSL=0

# CORS allowed origins (comma-separated). Default: * (any).
# In production set to your frontend URL(s):
# CORS_ORIGINS=https://insider-dashboard.example.com
CORS_ORIGINS=*

# ── Frontend ─────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000
